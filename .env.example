# Copy to .env and fill in. You need ONE LLM provider's key.

# Which LLM powers the decision: anthropic | openai | gemini
AIB_LLM_PROVIDER=anthropic

# --- Provider keys (set the one matching AIB_LLM_PROVIDER) --------------------
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# --- Model override ----------------------------------------------------------
# Defaults per provider: anthropic=claude-opus-4-8, openai=gpt-4o, gemini=gemini-2.5-pro
# AIB_MODEL=claude-opus-4-8

# OpenAI-compatible endpoints (OpenRouter, Together, Groq, local servers, ...).
# Set AIB_LLM_PROVIDER=openai, point this at the endpoint, and put its key in OPENAI_API_KEY.
# AIB_OPENAI_BASE_URL=https://openrouter.ai/api/v1

# --- Finnhub (free tier: 60 req/min, ~300/day) -------------------------------
# Set this and the bot AUTO-USES Finnhub for company news + fundamentals (much
# better than yfinance for both). Bulk price history stays on yfinance.
# Get a free key at https://finnhub.io/.
# FINNHUB_API_KEY=...

# --- Reasoning effort --------------------------------------------------------
# How hard the model THINKS before each decision (strategist / analyst / PM):
# off | low | medium | high. Default medium — the valuation is genuinely multi-step,
# and this is a once-a-day batch job so latency isn't a constraint. "off" is fastest/
# cheapest. OpenAI: maps to reasoning_effort. Gemini: a thinking budget. Anthropic:
# extended thinking (NOTE: forces temperature=1, trading away the low-temp+seed
# determinism — set "off" there if you need strict reproducibility).
# AIB_REASONING_EFFORT=medium

# --- Other optional overrides ------------------------------------------------
# All state lives under AIB_DATA_DIR. Point each model at its own folder to run
# independent experiments you can `aib compare` later. Leave it OUT of .env and
# set it per-command instead, e.g.:
#   AIB_DATA_DIR=runs/gemini AIB_LLM_PROVIDER=gemini uv run aib run
# AIB_DATA_DIR=./data
# Data providers. News/fundamentals default to finnhub IF FINNHUB_API_KEY is set,
# else yfinance. Set these to force a choice (e.g. yfinance to ignore Finnhub).
# AIB_PRICE_PROVIDER=yfinance
# AIB_FUNDAMENTALS_PROVIDER=finnhub
# AIB_NEWS_PROVIDER=finnhub
# AIB_MACRO_PROVIDER=yfinance
