# Copy to .env and fill in. You need ONE LLM provider's key.

# Which LLM powers the decision: anthropic | openai | gemini
AIB_LLM_PROVIDER=anthropic

# --- Provider keys (set the one matching AIB_LLM_PROVIDER) --------------------
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# --- Model override ----------------------------------------------------------
# Defaults per provider: anthropic=claude-opus-4-8, openai=gpt-4o, gemini=gemini-2.5-pro
# AIB_MODEL=claude-opus-4-8

# OpenAI-compatible endpoints (OpenRouter, Together, Groq, local servers, ...).
# Set AIB_LLM_PROVIDER=openai, point this at the endpoint, and put its key in OPENAI_API_KEY.
# AIB_OPENAI_BASE_URL=https://openrouter.ai/api/v1

# --- Other optional overrides ------------------------------------------------
# AIB_DATA_DIR=./data
# Data providers (default: yfinance for all). Swap to paid providers once
# registered in data/__init__.py.
# AIB_PRICE_PROVIDER=yfinance
# AIB_FUNDAMENTALS_PROVIDER=yfinance
# AIB_NEWS_PROVIDER=yfinance
# AIB_MACRO_PROVIDER=yfinance
